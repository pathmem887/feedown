# FeedOwn Environment Variables
# Copy this file to .env.shared and fill in your values
# Then run: yarn sync-envs

# ===========================================
# Supabase Configuration
# ===========================================
# Get these from your Supabase project settings > API

# Project URL (e.g., https://abcdefghij.supabase.co)
VITE_SUPABASE_URL=

# Anon/Public key (safe to use in frontend)
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# Cloudflare Workers (Optional - not currently used)
# ===========================================
# RSS fetching is handled directly by Pages Functions.
# Worker URL is kept for future browser-based RSS access features.
# VITE_WORKER_URL=https://feedown-worker.username.workers.dev

# ===========================================
# App Configuration
# ===========================================
VITE_APP_NAME=FeedOwn
VITE_APP_VERSION=1.0.0

# ===========================================
# Monitoring Scripts (Optional)
# ===========================================
# Used by scripts/check_usage.py and scripts/check_cloudflare.py
# to check free tier usage. Not required for running the app.

# Supabase personal access token (for actual DB size in check_usage.py)
# Get it from: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=

# Cloudflare API token (for check_cloudflare.py)
# Get it from: https://dash.cloudflare.com/profile/api-tokens
# Use the "Read all resources" template
# CLOUDFLARE_API_TOKEN=

# ===========================================
# Backend Only (Cloudflare Pages Secrets)
# ===========================================
# These should be set in Cloudflare Pages dashboard, not in .env.shared
#
# SUPABASE_URL=https://abcdefghij.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (keep this secret!)
